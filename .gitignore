# --- 全局忽略 ---

# IDE 配置文件 (VSCode, IntelliJ, Android Studio)
.idea/
.vscode/
*.iml
*.ipr
*.iws

# 操作系统生成的文件 (macOS, Windows)
.DS_Store
Thumbs.db

# 通用日志文件
*.log

# 敏感配置文件
.env
android/key.properties
key.properties
ios/ExportOptions.plist
application-dev.yml
application-prod.yml
application.yml

# 密钥库文件
*.jks
*.keystore
*.p12
*.mobileprovision

# 混淆符号文件
/debug-info/

document/
build/
MediaCrawler-main/
OpenViking/

# 本地拉取的参考仓库(仅供查阅文档,不入库)
/ag-ui/

# flutter
.flutter-plugins-dependencies
devtools_options.yaml
.dart_tool/

# git worktrees
.worktrees/

# Claude Code 本地配置
**/settings.local.json
