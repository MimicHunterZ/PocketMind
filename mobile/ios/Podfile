# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods 国内镜像源（解决 cdn.cocoapods.org 连接问题）
source 'https://mirrors.tuna.tsinghua.edu.cn/git/CocoaPods/Specs.git'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

# ShareExtension target 复用主 App 的 Flutter pods,这样 GeneratedPluginRegistrant
# 能在 Extension 进程内注册 path_provider / shared_preferences / isar 等插件。
target 'ShareExtension' do
  use_frameworks!
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # ShareExtension 复用了主 App 的全部 Flutter 插件,其中 permission_handler 等
      # 用到 [UIApplication sharedApplication] —— 该 API 在 App Extension 默认编译模式下被禁用,
      # 会导致编译报 "'sharedApplication' is unavailable: not available on iOS (App Extension)"。
      # 关掉 Extension-only API 限制即可正常编译(sideload / AltStore 安装不受影响)。
      # 注:这是侧载路线的折中;若要上架 App Store,需改用 extension_safe 引擎 +
      # 在 Extension 内只手动注册需要的插件,再把此项调回 YES。
      config.build_settings['APPLICATION_EXTENSION_API_ONLY'] = 'NO'
      # permission_handler 默认编译时禁用所有权限分组(减小体积)。
      # scheduleNotification 里用 Permission.notification.status 判权限,
      # 不加这个宏的话它在 iOS 上永远返回 denied(与系统实际状态无关),
      # 导致每次调度提醒都被误判成"未授权"而跳去系统设置。
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'PERMISSION_NOTIFICATIONS=1'
    end
  end

  # ShareExtension 的 app target 编译期需要能 `import Flutter` / `import FlutterPluginRegistrant`。
  # 主 App(Runner)靠 xcode_backend.sh 的 Run Script 把 Flutter.framework 拷进 BUILT_PRODUCTS_DIR,
  # 而 Extension target 没有这个阶段,搜索路径里也没有引擎,因此 import 报
  # "Unable to resolve module dependency: 'Flutter'"。
  # 这里给 Pods-ShareExtension 的 xcconfig 追加指向 extension_safe 引擎 xcframework 的搜索路径
  # 与弱链接,使 Extension 编译期能解析 Flutter 模块(运行时仍从宿主 App 的 Frameworks/ 加载同一份引擎)。
  engine_xcframework = File.join(
    flutter_root, 'bin', 'cache', 'artifacts', 'engine', 'ios', 'extension_safe', 'Flutter.xcframework'
  )
  installer.aggregate_targets.each do |agg|
    next unless agg.name == 'Pods-ShareExtension'
    agg.user_build_configurations.each_key do |config_name|
      xcconfig_path = agg.xcconfig_path(config_name)
      next unless File.exist?(xcconfig_path)
      File.open(xcconfig_path, 'a') do |f|
        f.puts ''
        f.puts '// PocketMind: 让 ShareExtension 编译期能 import Flutter(指向 extension_safe 引擎)'
        f.puts %(FRAMEWORK_SEARCH_PATHS[sdk=iphoneos*] = $(inherited) "#{engine_xcframework}/ios-arm64")
        f.puts %(FRAMEWORK_SEARCH_PATHS[sdk=iphonesimulator*] = $(inherited) "#{engine_xcframework}/ios-arm64_x86_64-simulator")
        f.puts 'OTHER_LDFLAGS = $(inherited) -framework Flutter'
      end
    end
  end
end
