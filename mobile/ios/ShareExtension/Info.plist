<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Share Extension 有 ~120MB 内存上限,Impeller 渲染峰值内存更高,
	     关掉改用 Skia 以降低被 jetsam 杀进程的概率。 -->
	<key>FLTEnableImpeller</key>
	<false/>
	<key>NSExtension</key>
	<dict>
		<key>NSExtensionAttributes</key>
		<dict>
			<!-- 与 Android ShareActivity 的 intent-filter (text/* image/* video/* application/*) 对齐,
			     做到「近乎全收」。
			     不用 dict 形式 (SupportsText/WebURL/Image...) 是因为 dict 规则要求分享 payload 里
			     每一个 attachment 都落进声明的桶里才激活;知乎等国内 App 常夹带私有 UTI(富文本/卡片),
			     只要有一项不命中整条规则就失败,导致 PocketMind 从分享面板消失。
			     TRUEPREDICATE 对任意分享内容都激活,真正能否取到内容交给 ShareViewController 的兜底解析。 -->
			<key>NSExtensionActivationRule</key>
			<string>TRUEPREDICATE</string>
		</dict>
		<key>NSExtensionMainStoryboard</key>
		<string>MainInterface</string>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.share-services</string>
	</dict>
</dict>
</plist>
